//@version=5
strategy("BTC 3m EMA20 Imbalance + A 3-Wave Short v0.3", overlay=true, initial_capital=10000, pyramiding=0, default_qty_type=strategy.percent_of_equity, default_qty_value=100, margin_long=100, margin_short=100, commission_type=strategy.commission.percent, commission_value=0.04, process_orders_on_close=true, calc_on_every_tick=false)

// =====================================================
// V0.3 修复重点：
// 1) 显式 from_entry 出场，避免有入场但没有退出单。
// 2) 止损固定为结构高/低点：空单放结构最高点上方，多单放结构最低点下方。
// 3) 止盈改为 R 倍，并支持分批止盈、保本、时间退出、EMA20失效退出。
// 4) 放宽三波分布条件，并允许三波确认后若干根K线内触发，提高交易频率。
// =====================================================

// =============================
// Inputs: general
// =============================
tradeMode = input.string("Both", "Trade direction", options=["Both", "Long only", "Short only"])
enableV01 = input.bool(true, "Enable V0.1 EMA20 imbalance signals")
enableA3Short = input.bool(true, "Enable A-version 3-wave distribution short")

emaLen = input.int(20, "EMA length", minval=1)
ema50Len = input.int(50, "EMA50 length", minval=1)
ema200Len = input.int(200, "EMA200 length", minval=1)
atrLen = input.int(14, "ATR length", minval=1)
showScores = input.bool(true, "Show signal labels")
showRiskLines = input.bool(true, "Show active stop / target lines")

// =============================
// Inputs: V0.1 EMA20 imbalance module - defaults loosened for more trades
// =============================
trendLookback = input.int(36, "V0.1 imbalance lookback bars", minval=10)
minAgeBars = input.int(10, "V0.1 minimum one-sided bars", minval=3)
maxCrossCount = input.float(6.0, "V0.1 max EMA crosses in lookback", minval=0.0, step=1.0)
minRangeATR = input.float(1.2, "V0.1 minimum range / ATR", minval=0.1, step=0.1)
minExtensionATR = input.float(0.8, "V0.1 minimum extension from EMA / ATR", minval=0.1, step=0.1)
touchDistanceATR = input.float(0.65, "V0.1 near EMA distance / ATR", minval=0.05, step=0.05)
slopeNowBars = input.int(6, "V0.1 EMA slope recent bars", minval=1)
slopePastBars = input.int(20, "V0.1 EMA slope past bars", minval=2)
minPastSlopeATR = input.float(0.25, "V0.1 minimum past EMA slope / ATR", minval=0.01, step=0.01)
flattenRatio = input.float(0.70, "V0.1 flatten ratio", minval=0.05, maxval=1.0, step=0.05)
wickRatioMin = input.float(0.18, "V0.1 rejection wick ratio", minval=0.0, maxval=1.0, step=0.01)
entryScoreMin = input.float(62.0, "V0.1 minimum entry score", minval=0.0, maxval=100.0, step=1.0)

// =============================
// Inputs: A-version 3-wave distribution short module - defaults loosened
// =============================
impulseLookbackA = input.int(96, "A prior rise lookback bars", minval=20)
minImpulseATRA = input.float(3.0, "A minimum prior rise / ATR", minval=0.5, step=0.5)
aboveRatioMinA = input.float(0.45, "A above EMA20 ratio in prior rise", minval=0.1, maxval=1.0, step=0.05)

pivotLeftA = input.int(3, "A pivot left bars", minval=1)
pivotRightA = input.int(3, "A pivot right bars", minval=1)
triggerWindowA = input.int(12, "A trigger window after 3rd wave", minval=1)
minWaveSpacingA = input.int(3, "A minimum bars between wave highs", minval=1)
minPatternBarsA = input.int(10, "A minimum 3-wave duration", minval=3)
maxPatternBarsA = input.int(120, "A maximum 3-wave duration", minval=10)
waveHighToleranceATRA = input.float(1.8, "A wave high cluster tolerance / ATR", minval=0.1, step=0.1)
falseBreakATRA = input.float(1.0, "A allowed 3rd-wave false break / ATR", minval=0.0, step=0.1)

emaSlopeBarsA = input.int(12, "A EMA20 flatten bars", minval=2)
maxFlatSlopeATRA = input.float(0.75, "A max EMA20 slope while distributing / ATR", minval=0.01, step=0.01)
thirdWickMinA = input.float(0.12, "A minimum 3rd-wave upper wick ratio", minval=0.0, maxval=1.0, step=0.01)
triggerModeA = input.string("Aggressive", "A trigger mode", options=["Aggressive", "Close below EMA20", "Bear candle below EMA20"])

// =============================
// Inputs: risk / exit model
// =============================
stopLookback = input.int(10, "Structure stop lookback", minval=2)
stopATRBuffer = input.float(0.15, "V0.1 structure stop ATR buffer", minval=0.0, step=0.01)
stopATRBufferA = input.float(0.20, "A structure stop ATR buffer", minval=0.0, step=0.05)
minRiskATR = input.float(0.15, "Minimum risk / ATR", minval=0.01, step=0.01)
maxRiskATR = input.float(4.0, "Maximum risk / ATR", minval=0.1, step=0.1)

usePartialTP = input.bool(true, "Use partial take profit")
tp1RR = input.float(1.5, "TP1 RR", minval=0.2, step=0.1)
tp2RR = input.float(3.0, "TP2 RR", minval=0.5, step=0.5)
tp1Percent = input.float(50.0, "TP1 position percent", minval=1.0, maxval=99.0, step=1.0)
useBreakEven = input.bool(true, "Move stop to breakeven after TP1")
useEmaInvalidExit = input.bool(true, "Exit when EMA20 invalidates trade")
minHoldBarsBeforeEmaExit = input.int(3, "Minimum hold bars before EMA exit", minval=0)
useTimeExit = input.bool(true, "Use time exit")
maxBarsInTrade = input.int(80, "Maximum bars in trade", minval=1)

// =============================
// Helpers
// =============================
f_clamp(x, lo, hi) =>
    math.max(lo, math.min(hi, x))

f_score(x, lo, hi) =>
    hi == lo ? 0.0 : f_clamp((x - lo) / (hi - lo), 0.0, 1.0)

f_barRange(offset) =>
    math.max(high[offset] - low[offset], syminfo.mintick)

f_upperWickRatio(offset) =>
    (high[offset] - math.max(open[offset], close[offset])) / f_barRange(offset)

// =============================
// Base series
// =============================
ema20 = ta.ema(close, emaLen)
ema50 = ta.ema(close, ema50Len)
ema200 = ta.ema(close, ema200Len)
atr = ta.atr(atrLen)
barRange = math.max(high - low, syminfo.mintick)
bodyTop = math.max(open, close)
bodyBottom = math.min(open, close)
upperWickRatio = (high - bodyTop) / barRange
lowerWickRatio = (bodyBottom - low) / barRange

plot(ema20, "EMA20", color=color.red, linewidth=2)
plot(ema50, "EMA50", color=color.orange, linewidth=1)
plot(ema200, "EMA200", color=color.aqua, linewidth=1)

allowLong = tradeMode == "Both" or tradeMode == "Long only"
allowShort = tradeMode == "Both" or tradeMode == "Short only"

// =====================================================
// Module 1: V0.1 EMA20 imbalance exhaustion
// =====================================================
crossEvent = ta.cross(close, ema20) ? 1.0 : 0.0
crossCount = math.sum(crossEvent, trendLookback)
rangeATR = atr > 0 ? (ta.highest(high, trendLookback) - ta.lowest(low, trendLookback)) / atr : 0.0
notChoppy = crossCount <= maxCrossCount and rangeATR >= minRangeATR

upAgeRaw = ta.barssince(close < ema20)
downAgeRaw = ta.barssince(close > ema20)
upAge = na(upAgeRaw) ? trendLookback + 1 : upAgeRaw
downAge = na(downAgeRaw) ? trendLookback + 1 : downAgeRaw

emaSlopeNow = atr > 0 ? (ema20 - ema20[slopeNowBars]) / atr : 0.0
emaSlopePast = atr > 0 ? (ema20[slopeNowBars] - ema20[slopePastBars]) / atr : 0.0
upFlatten = emaSlopePast > minPastSlopeATR and emaSlopeNow < emaSlopePast * flattenRatio
downFlatten = emaSlopePast < -minPastSlopeATR and emaSlopeNow > emaSlopePast * flattenRatio

upExtensionATR = atr > 0 ? ta.highest(high - ema20, trendLookback) / atr : 0.0
downExtensionATR = atr > 0 ? ta.highest(ema20 - low, trendLookback) / atr : 0.0

distanceToEmaATR = atr > 0 ? math.abs(close - ema20) / atr : 10.0
touchScore = 1.0 - f_clamp(distanceToEmaATR / touchDistanceATR, 0.0, 1.0)

badCandleShort = close < open and close < close[1]
badCandleLong = close > open and close > close[1]

shortRejectionScore = f_clamp(upperWickRatio / math.max(wickRatioMin, 0.01), 0.0, 1.0)
longRejectionScore = f_clamp(lowerWickRatio / math.max(wickRatioMin, 0.01), 0.0, 1.0)
shortAgeScore = f_score(upAge, minAgeBars, trendLookback)
longAgeScore = f_score(downAge, minAgeBars, trendLookback)
shortExtensionScore = f_score(upExtensionATR, minExtensionATR, minExtensionATR * 2.0)
longExtensionScore = f_score(downExtensionATR, minExtensionATR, minExtensionATR * 2.0)
shortFlattenScore = upFlatten ? 1.0 : 0.0
longFlattenScore = downFlatten ? 1.0 : 0.0
shortConfirmScore = badCandleShort ? 1.0 : 0.0
longConfirmScore = badCandleLong ? 1.0 : 0.0

shortScore = 20.0 * shortAgeScore + 20.0 * shortExtensionScore + 20.0 * shortFlattenScore + 20.0 * touchScore + 10.0 * shortRejectionScore + 10.0 * shortConfirmScore
longScore = 20.0 * longAgeScore + 20.0 * longExtensionScore + 20.0 * longFlattenScore + 20.0 * touchScore + 10.0 * longRejectionScore + 10.0 * longConfirmScore

// Structure stops: long below recent lowest low, short above recent highest high.
longStopV01 = ta.lowest(low, stopLookback) - atr * stopATRBuffer
shortStopV01 = ta.highest(high, stopLookback) + atr * stopATRBuffer
longRiskV01 = close - longStopV01
shortRiskV01 = shortStopV01 - close
validLongRiskV01 = atr > 0 and longRiskV01 >= atr * minRiskATR and longRiskV01 <= atr * maxRiskATR
validShortRiskV01 = atr > 0 and shortRiskV01 >= atr * minRiskATR and shortRiskV01 <= atr * maxRiskATR

longSignalV01 = enableV01 and allowLong and strategy.position_size == 0 and notChoppy and downAge >= minAgeBars and longScore >= entryScoreMin and badCandleLong and validLongRiskV01
shortSignalV01 = enableV01 and allowShort and strategy.position_size == 0 and notChoppy and upAge >= minAgeBars and shortScore >= entryScoreMin and badCandleShort and validShortRiskV01

// =====================================================
// Module 2: A-version aggressive 3-wave distribution short
// =====================================================
priorLowA = ta.lowest(low, impulseLookbackA)
priorHighA = ta.highest(high, impulseLookbackA)
priorRiseATRA = atr > 0 ? (priorHighA - priorLowA) / atr : 0.0
aboveEmaCountA = math.sum(close > ema20 ? 1.0 : 0.0, impulseLookbackA)
aboveEmaRatioA = impulseLookbackA > 0 ? aboveEmaCountA / impulseLookbackA : 0.0
backgroundRiseA = priorRiseATRA >= minImpulseATRA and aboveEmaRatioA >= aboveRatioMinA

emaSlopeATRA = atr > 0 ? math.abs(ema20 - ema20[emaSlopeBarsA]) / atr : 999.0
emaFlattenA = emaSlopeATRA <= maxFlatSlopeATRA

phA = ta.pivothigh(high, pivotLeftA, pivotRightA)
newPivotHighA = not na(phA)

var float ph1A = na
var float ph2A = na
var float ph3A = na
var int ph1BarA = na
var int ph2BarA = na
var int ph3BarA = na
var float ph1WickA = na
var float ph2WickA = na
var float ph3WickA = na

var bool pendingA = false
var int pendingAStartBar = na
var float pendingAStop = na
var float pendingAPivotHigh = na
var float pendingAHighClusterATR = na

if newPivotHighA
    ph3A := ph2A
    ph3BarA := ph2BarA
    ph3WickA := ph2WickA
    ph2A := ph1A
    ph2BarA := ph1BarA
    ph2WickA := ph1WickA
    ph1A := phA
    ph1BarA := bar_index - pivotRightA
    ph1WickA := f_upperWickRatio(pivotRightA)

have3WavesA = not na(ph1A) and not na(ph2A) and not na(ph3A)
waveSpacingOkA = have3WavesA and (ph2BarA - ph3BarA >= minWaveSpacingA) and (ph1BarA - ph2BarA >= minWaveSpacingA)
patternBarsA = have3WavesA ? ph1BarA - ph3BarA : 0
patternDurationOkA = have3WavesA and patternBarsA >= minPatternBarsA and patternBarsA <= maxPatternBarsA
highClusterATRA = have3WavesA and atr > 0 ? (math.max(ph1A, math.max(ph2A, ph3A)) - math.min(ph1A, math.min(ph2A, ph3A))) / atr : 999.0
highClusterOkA = highClusterATRA <= waveHighToleranceATRA
thirdNoStrongBreakA = have3WavesA and atr > 0 and ph1A <= math.max(ph2A, ph3A) + falseBreakATRA * atr
thirdRejectionA = have3WavesA and ph1WickA >= thirdWickMinA

patternQualifiedA = enableA3Short and allowShort and backgroundRiseA and emaFlattenA and have3WavesA and waveSpacingOkA and patternDurationOkA and highClusterOkA and thirdNoStrongBreakA and thirdRejectionA

// When the third-wave pivot is confirmed, keep a pending short setup alive for N bars.
if newPivotHighA and patternQualifiedA
    pendingA := true
    pendingAStartBar := bar_index
    pendingAPivotHigh := ph1A
    pendingAStop := ph1A + atr * stopATRBufferA
    pendingAHighClusterATR := highClusterATRA

pendingAValid = pendingA and not na(pendingAStartBar) and bar_index - pendingAStartBar <= triggerWindowA
if pendingA and not pendingAValid
    pendingA := false
    pendingAStartBar := na
    pendingAStop := na
    pendingAPivotHigh := na
    pendingAHighClusterATR := na

triggerAggressiveA = close < close[1] and close < pendingAPivotHigh
triggerBelowEmaA = close < ema20
triggerStrictA = close < ema20 and close < open and close < close[1]
triggerOkA = triggerModeA == "Aggressive" ? triggerAggressiveA : triggerModeA == "Close below EMA20" ? triggerBelowEmaA : triggerStrictA

shortRiskA = pendingAValid and not na(pendingAStop) ? pendingAStop - close : na
validRiskA = pendingAValid and atr > 0 and shortRiskA >= atr * minRiskATR and shortRiskA <= atr * maxRiskATR
shortSignalA = enableA3Short and allowShort and strategy.position_size == 0 and pendingAValid and triggerOkA and validRiskA

// =====================================================
// Orders and active exits
// =====================================================
var float activeLongStop = na
var float activeLongTP1 = na
var float activeLongTP2 = na
var float activeShortStop = na
var float activeShortTP1 = na
var float activeShortTP2 = na
var int entryBar = na

if longSignalV01
    activeLongStop := longStopV01
    activeLongTP1 := close + longRiskV01 * tp1RR
    activeLongTP2 := close + longRiskV01 * tp2RR
    entryBar := bar_index
    strategy.entry("L-V01", strategy.long, comment="V0.1 EMA20 exhaustion long")

if shortSignalA
    activeShortStop := pendingAStop
    activeShortTP1 := close - shortRiskA * tp1RR
    activeShortTP2 := close - shortRiskA * tp2RR
    entryBar := bar_index
    strategy.entry("S-A3", strategy.short, comment="A 3-wave distribution short")
    pendingA := false
    pendingAStartBar := na
    pendingAStop := na
    pendingAPivotHigh := na
    pendingAHighClusterATR := na
else if shortSignalV01
    activeShortStop := shortStopV01
    activeShortTP1 := close - shortRiskV01 * tp1RR
    activeShortTP2 := close - shortRiskV01 * tp2RR
    entryBar := bar_index
    strategy.entry("S-V01", strategy.short, comment="V0.1 EMA20 exhaustion short")

barsInTrade = strategy.position_size != 0 and not na(entryBar) ? bar_index - entryBar : 0

// Breakeven after TP1 touch.
if strategy.position_size > 0 and useBreakEven and not na(activeLongTP1) and high >= activeLongTP1
    activeLongStop := math.max(activeLongStop, strategy.position_avg_price)

if strategy.position_size < 0 and useBreakEven and not na(activeShortTP1) and low <= activeShortTP1
    activeShortStop := math.min(activeShortStop, strategy.position_avg_price)

// Explicit from_entry exits. This is the main fix for the no-exit problem.
if strategy.position_size > 0
    if usePartialTP
        strategy.exit("LX1-V01", from_entry="L-V01", stop=activeLongStop, limit=activeLongTP1, qty_percent=tp1Percent)
        strategy.exit("LX2-V01", from_entry="L-V01", stop=activeLongStop, limit=activeLongTP2, qty_percent=100.0 - tp1Percent)
    else
        strategy.exit("LX-V01", from_entry="L-V01", stop=activeLongStop, limit=activeLongTP2, qty_percent=100)

if strategy.position_size < 0
    if usePartialTP
        strategy.exit("SX1-V01", from_entry="S-V01", stop=activeShortStop, limit=activeShortTP1, qty_percent=tp1Percent)
        strategy.exit("SX2-V01", from_entry="S-V01", stop=activeShortStop, limit=activeShortTP2, qty_percent=100.0 - tp1Percent)
        strategy.exit("SX1-A3", from_entry="S-A3", stop=activeShortStop, limit=activeShortTP1, qty_percent=tp1Percent)
        strategy.exit("SX2-A3", from_entry="S-A3", stop=activeShortStop, limit=activeShortTP2, qty_percent=100.0 - tp1Percent)
    else
        strategy.exit("SX-V01", from_entry="S-V01", stop=activeShortStop, limit=activeShortTP2, qty_percent=100)
        strategy.exit("SX-A3", from_entry="S-A3", stop=activeShortStop, limit=activeShortTP2, qty_percent=100)

// EMA20 invalidation exit: if trade goes back through EMA20 after minimum hold, close it.
if useEmaInvalidExit and strategy.position_size > 0 and barsInTrade >= minHoldBarsBeforeEmaExit and close < ema20
    strategy.close("L-V01", comment="EMA20 invalid long")

if useEmaInvalidExit and strategy.position_size < 0 and barsInTrade >= minHoldBarsBeforeEmaExit and close > ema20
    strategy.close("S-V01", comment="EMA20 invalid short")
    strategy.close("S-A3", comment="EMA20 invalid short")

// Time exit: prevent trades from never closing when neither stop nor target is touched.
if useTimeExit and strategy.position_size != 0 and barsInTrade >= maxBarsInTrade
    strategy.close("L-V01", comment="Time exit")
    strategy.close("S-V01", comment="Time exit")
    strategy.close("S-A3", comment="Time exit")

if strategy.position_size == 0
    activeLongStop := na
    activeLongTP1 := na
    activeLongTP2 := na
    activeShortStop := na
    activeShortTP1 := na
    activeShortTP2 := na
    entryBar := na

// =====================================================
// Visuals and alerts
// =====================================================
plot(showRiskLines ? activeLongStop : na, "Active long stop", color=color.new(color.red, 0), style=plot.style_linebr)
plot(showRiskLines ? activeLongTP1 : na, "Active long TP1", color=color.new(color.green, 0), style=plot.style_linebr)
plot(showRiskLines ? activeLongTP2 : na, "Active long TP2", color=color.new(color.green, 40), style=plot.style_linebr)
plot(showRiskLines ? activeShortStop : na, "Active short stop", color=color.new(color.red, 0), style=plot.style_linebr)
plot(showRiskLines ? activeShortTP1 : na, "Active short TP1", color=color.new(color.green, 0), style=plot.style_linebr)
plot(showRiskLines ? activeShortTP2 : na, "Active short TP2", color=color.new(color.green, 40), style=plot.style_linebr)

plotshape(longSignalV01, title="V0.1 Long", style=shape.triangleup, location=location.belowbar, size=size.small, text="L1")
plotshape(shortSignalV01, title="V0.1 Short", style=shape.triangledown, location=location.abovebar, size=size.small, text="S1")
plotshape(shortSignalA, title="A-version 3-wave short", style=shape.triangledown, location=location.abovebar, size=size.normal, text="A空")
plotshape(pendingAValid, title="A pending setup", style=shape.circle, location=location.abovebar, size=size.tiny, text="A?")

if showScores and longSignalV01
    label.new(bar_index, low, "V0.1 L " + str.tostring(longScore, "#.0") + "\nSL=" + str.tostring(activeLongStop, "#.0"), style=label.style_label_up, textcolor=color.white)

if showScores and shortSignalV01
    label.new(bar_index, high, "V0.1 S " + str.tostring(shortScore, "#.0") + "\nSL=" + str.tostring(activeShortStop, "#.0"), style=label.style_label_down, textcolor=color.white)

if showScores and shortSignalA
    label.new(bar_index, high, "A空\nRisk=" + str.tostring(shortRiskA / atr, "#.00") + " ATR\nSL=" + str.tostring(activeShortStop, "#.0"), style=label.style_label_down, textcolor=color.white)

alertcondition(longSignalV01, title="V0.1 EMA20 exhaustion LONG", message="V0.1 BTC EMA20 imbalance exhaustion long signal")
alertcondition(shortSignalV01, title="V0.1 EMA20 exhaustion SHORT", message="V0.1 BTC EMA20 imbalance exhaustion short signal")
alertcondition(shortSignalA, title="A-version 3-wave distribution SHORT", message="A-version BTC 3-wave distribution aggressive short signal")
